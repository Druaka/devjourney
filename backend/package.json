{
  "name": "devjourney-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest --runInBand",
    "coverage": "jest --coverage"
  },
  "dependencies": {
    "@tcgdex/sdk": "^2.6.0",
    "cors": "^2.8.5",
    "devjourney-monorepo": "file:..",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "fs": "^0.0.1-security",
    "mongoose": "^8.14.1",
    "throttled-queue": "^2.1.4",
    "undici": "^7.9.0"
  }
  ,
  "devDependencies": {
    "jest": "^29.6.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": ["<rootDir>/test/utils/setupTests.js"],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.js",
      "routes/**/*.js",
      "*.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text","lcov","html"],
    "coverageThreshold": {
      "global": {
        "branches": 85,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    }
  }
}
